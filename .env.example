# Echoquize configuration — copy to .env and fill in.

# REQUIRED — OpenAI API key with TTS access. App fails fast at startup if unset.
OPENAI_API_KEY=sk-...

# Storage + DB locations (defaults shown). In Docker these point at /app/data.
AUDIO_DIR=./audio
DB_PATH=./echoquize.db

# Server bind. HOST MUST be 0.0.0.0 inside a container (do not use 127.0.0.1).
HOST=0.0.0.0
PORT=7860

# Storage backend: local (default) | s3 | gdrive
STORAGE_BACKEND=local

# Optional single-owner login. Leave both unset for no authentication (default).
# UI_USERNAME=admin
# UI_PASSWORD=change-me
