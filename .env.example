# Echoquize configuration — copy to .env and fill in (`cp .env.example .env`).
# Every runtime knob is read from the environment (Constitution Principle III),
# so one built image runs unchanged locally, in Docker, and on a VPS.

# REQUIRED — OpenAI API key with TTS access. App fails fast at startup if unset.
OPENAI_API_KEY=sk-...

# Storage + DB locations (local-dev defaults shown).
# In Docker these are overridden by compose.yml to live under the ./data mount
# (AUDIO_DIR=/app/data/audio, DB_PATH=/app/data/echoquize.db).
AUDIO_DIR=./audio
DB_PATH=./echoquize.db

# Server bind. HOST MUST be 0.0.0.0 inside a container (127.0.0.1 is unreachable
# from outside it). PORT is the published port; compose maps ${PORT}:7860.
HOST=0.0.0.0
PORT=7860

# ---------------------------------------------------------------------------
# Storage backend: local (default) | s3 | gdrive
# Switching this requires NO code change (Constitution Principle I). Only
# `local` is implemented today; `s3`/`gdrive` are ready-to-wire stubs that raise
# a clear NotImplementedError until completed.
STORAGE_BACKEND=local

# --- s3 backend (only read when STORAGE_BACKEND=s3) ---
# Install the optional dependency first: `uv sync --extra s3`.
# S3_BUCKET=my-echoquize-bucket
# S3_ENDPOINT_URL=https://s3.amazonaws.com   # or a MinIO/R2-compatible endpoint
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# --- gdrive backend (only read when STORAGE_BACKEND=gdrive) ---
# GDRIVE_FOLDER_ID=...
# GDRIVE_CREDENTIALS_JSON=/app/data/gdrive-credentials.json

# ---------------------------------------------------------------------------
# Optional single-owner login. Leave BOTH unset for no authentication (default).
# Auth is enforced only when both are set.
# UI_USERNAME=admin
# UI_PASSWORD=change-me

# ---------------------------------------------------------------------------
# Docker / persistence note (Constitution Principles IV & V):
# Audio files and the SQLite DB persist on the ./data bind mount, NOT in the
# image. Before the first `docker compose up`, create it owned by the non-root
# runtime user (uid 999) so the container can write to it:
#
#     mkdir -p data && sudo chown -R 999:999 data
#
# `docker compose down` keeps your data; NEVER run `docker compose down -v`
# (the -v flag deletes the volume and destroys every saved generation).
#
# Storage growth: generations are kept indefinitely — there is no auto-pruning.
# Reclaim space periodically via the Library tab's "Bulk cleanup" (by date/voice),
# or prune old files under ./data/audio yourself. Audio plus the SQLite row grow
# with every generation, so check disk usage if you generate heavily.
